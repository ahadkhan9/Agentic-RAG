# ============================================================
# Agentic RAG — Environment Configuration
# ============================================================
# This file is a TEMPLATE. Copy to .env and fill in values.
# The only REQUIRED field is GOOGLE_API_KEY (if not using
# per-session key input via the Streamlit landing page).
# ============================================================

# --- Gemini LLM ---
GEMINI_MODEL=gemini-3.1-flash-lite-preview

# --- Gemini Embeddings ---
EMBEDDING_MODEL=gemini-embedding-001
EMBEDDING_DIM=3072

# --- Server-level API Key (optional) ---
# If set, this key is used as fallback when users don't provide one.
# For public hosting, leave blank and let users provide their own.
GOOGLE_API_KEY=

# --- Collection Settings ---
COLLECTION_NAME=documents
CHUNK_SIZE=512
CHUNK_OVERLAP=50

# --- Security ---
MAX_UPLOAD_SIZE_MB=20
# Comma-separated allowed CORS origins. Use * for open access.
ALLOWED_ORIGINS=*
# Set to "true" to enable /docs endpoint (FastAPI Swagger UI)
ENABLE_DOCS=false
